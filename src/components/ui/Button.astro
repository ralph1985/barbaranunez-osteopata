---
interface Props {
  href: string;
  variant?: "primary" | "secondary" | "light" | "outlineLight";
  target?: "_blank";
  rel?: string;
}

const { href, variant = "primary", target, rel } = Astro.props;
---

<a
  class:list={["button", `button--${variant}`]}
  href={href}
  target={target}
  rel={rel}
>
  <slot />
</a>
