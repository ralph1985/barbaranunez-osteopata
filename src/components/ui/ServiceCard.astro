---
import type { Service } from "../../domain/site";

interface Props {
  service: Service;
}

const { service } = Astro.props;
---

<article
  class="min-h-64 overflow-hidden rounded-md border border-line bg-surface/85 p-5 shadow-card"
>
  <span class="mb-4 block h-1 w-9 rounded-full bg-warm" aria-hidden="true"
  ></span>
  <h3 class="mb-3 mt-0 text-xl leading-tight font-bold">{service.title}</h3>
  <p class="text-muted">{service.summary}</p>
</article>
