---
interface Props {
  eyebrow: string;
  title: string;
  description: string;
  aspectClass?: string;
  className?: string;
  [key: string]: unknown;
}

const {
  eyebrow,
  title,
  description,
  aspectClass = "photo-placeholder--landscape",
  className = "",
  ...attrs
} = Astro.props;
---

<figure {...attrs} class:list={["photo-placeholder", aspectClass, className]}>
  <div class="photo-placeholder__wash"></div>
  <div class="photo-placeholder__frame"></div>
  <div class="photo-placeholder__ring photo-placeholder__ring--large"></div>
  <div class="photo-placeholder__ring photo-placeholder__ring--small"></div>
  <figcaption class="photo-placeholder__caption">
    <p class="eyebrow">
      {eyebrow}
    </p>
    <p class="photo-placeholder__title">
      {title}
    </p>
    <p class="photo-placeholder__description">{description}</p>
  </figcaption>
</figure>
