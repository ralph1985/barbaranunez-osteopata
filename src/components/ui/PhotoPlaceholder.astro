---
interface Props {
  eyebrow: string;
  title: string;
  description: string;
  aspectClass?: string;
  className?: string;
  waterScene?: boolean;
  [key: string]: unknown;
}

const {
  eyebrow,
  title,
  description,
  aspectClass = "photo-placeholder--landscape",
  className = "",
  waterScene = false,
  ...attrs
} = Astro.props;
---

<figure
  {...attrs}
  class:list={[
    "photo-placeholder",
    aspectClass,
    waterScene && "photo-placeholder--water-scene",
    className,
  ]}
>
  <div class="photo-placeholder__wash"></div>
  {
    waterScene && (
      <div class="photo-placeholder__water" aria-hidden="true" data-water-scene>
        <div class="photo-placeholder__water-glow" />
        <div class="photo-placeholder__drop" data-water-drop />
        <div class="photo-placeholder__impact" data-water-impact />
        <div class="photo-placeholder__surface">
          <span data-water-ripple />
          <span data-water-ripple />
          <span data-water-ripple />
        </div>
      </div>
    )
  }
  <div class="photo-placeholder__frame"></div>
  <div class="photo-placeholder__ring photo-placeholder__ring--large"></div>
  <div class="photo-placeholder__ring photo-placeholder__ring--small"></div>
  <figcaption class="photo-placeholder__caption">
    <p class="eyebrow">
      {eyebrow}
    </p>
    <p class="photo-placeholder__title">
      {title}
    </p>
    <p class="photo-placeholder__description">{description}</p>
  </figcaption>
</figure>
