---
interface Props {
  eyebrow: string;
  title: string;
  description: string;
}

const { eyebrow, title, description } = Astro.props;
---

<header class="page-intro page-shell" data-animate>
  <p class="eyebrow">
    {eyebrow}
  </p>
  <h1 class="page-intro__title">
    {title}
  </h1>
  <p class="page-intro__description">{description}</p>
</header>
