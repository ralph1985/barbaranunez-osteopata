---
interface Props {
  eyebrow: string;
  title: string;
  description: string;
}

const { eyebrow, title, description } = Astro.props;
---

<header class="mx-auto w-page py-16 max-md:py-12" data-animate>
  <p
    class="mb-3 text-xs font-extrabold tracking-wide text-accent-strong uppercase"
  >
    {eyebrow}
  </p>
  <h1
    class="m-0 max-w-4xl text-[clamp(2.6rem,6vw,5rem)] leading-[1.05] font-bold"
  >
    {title}
  </h1>
  <p class="mt-5 max-w-2xl text-lg text-muted">{description}</p>
</header>
