---
import ContactActions from "./ContactActions.astro";
import type { ContactInfo } from "../../domain/site";

interface Props {
  contact: ContactInfo;
}

const { contact } = Astro.props;
---

<div class="contact-panel">
  <p class="contact-panel__eyebrow">
    {contact.copy.eyebrow}
  </p>
  <h2 id="contact-title" class="contact-panel__title">
    {contact.copy.title}
  </h2>
  <div class="contact-panel__details">
    <p>{contact.address}</p>
    <p>{contact.city}</p>
    <p>
      <a href={contact.whatsappHref} target="_blank" rel="noopener noreferrer"
        >WhatsApp</a
      >
    </p>
    <p>
      <a href={`tel:${contact.phone.replace(/\s+/g, "")}`}>{contact.phone}</a>
      {
        contact.landline && (
          <>
            {" / "}
            <a href={`tel:${contact.landline.replace(/\s+/g, "")}`}>
              {contact.landline}
            </a>
          </>
        )
      }
    </p>
    <p>
      <a href={`mailto:${contact.email}`}>{contact.email}</a>
    </p>
    {
      contact.facebookHref && (
        <p>
          <a
            href={contact.facebookHref}
            target="_blank"
            rel="noopener noreferrer"
          >
            Facebook
          </a>
        </p>
      )
    }
  </div>
  <div class="contact-panel__actions">
    <ContactActions
      email={contact.email}
      phone={contact.phone}
      whatsappHref={contact.whatsappHref}
      facebookHref={contact.facebookHref}
      primaryVariant="light"
      secondaryVariant="outlineLight"
      tertiaryVariant="outlineLight"
      quaternaryVariant="outlineLight"
    />
  </div>
</div>
