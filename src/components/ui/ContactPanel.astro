---
import ContactActions from "./ContactActions.astro";
import type { ContactInfo } from "../../domain/site";

interface Props {
  contact: ContactInfo;
}

const { contact } = Astro.props;
---

<div class="rounded-md bg-accent-strong p-8 text-white">
  <p class="mb-3 text-xs font-extrabold tracking-wide uppercase">Contacto</p>
  <h2
    id="contact-title"
    class="m-0 text-[clamp(2rem,4.6vw,3.7rem)] leading-[1.05] font-bold"
  >
    Cita previa y ubicación
  </h2>
  <div class="mt-6 space-y-3 text-white">
    <p>{contact.address}</p>
    <p>{contact.city}</p>
    <p>
      <a href={contact.whatsappHref} target="_blank" rel="noopener noreferrer"
        >WhatsApp</a
      >
    </p>
    <p>
      <a href={`tel:${contact.phone.replace(/\s+/g, "")}`}>{contact.phone}</a>
      {
        contact.landline && (
          <>
            {" / "}
            <a href={`tel:${contact.landline.replace(/\s+/g, "")}`}>
              {contact.landline}
            </a>
          </>
        )
      }
    </p>
    <p>
      <a href={`mailto:${contact.email}`}>{contact.email}</a>
    </p>
  </div>
  <div class="mt-6">
    <ContactActions
      email={contact.email}
      phone={contact.phone}
      whatsappHref={contact.whatsappHref}
      primaryVariant="light"
      secondaryVariant="outlineLight"
      tertiaryVariant="outlineLight"
    />
  </div>
</div>
