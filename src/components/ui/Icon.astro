---
import type { IconName } from "../../domain/icon";

interface Props {
  name: IconName;
  className?: string;
}

const { name, className = "" } = Astro.props;
---

<svg
  class:list={["icon", className]}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.8"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  focusable="false"
>
  {
    name === "appointment" && (
      <>
        <rect x="4" y="5" width="16" height="15" rx="2.5" />
        <path d="M8 3.5v3" />
        <path d="M16 3.5v3" />
        <path d="M4 10h16" />
        <path d="m8.5 15 2.1 2 4.9-5" />
      </>
    )
  }
  {
    name === "contact" && (
      <>
        <path d="M4.5 6.5h15v11h-15z" />
        <path d="m5 7 7 5 7-5" />
        <path d="M8 17.5 4.8 21" />
        <path d="M16 17.5 19.2 21" />
      </>
    )
  }
  {
    name === "craniosacral" && (
      <>
        <path d="M12 4.5c-2.7 0-4.9 2-4.9 4.7 0 1.4.5 2.4 1.3 3.3.8.9 1.2 1.8 1.2 3v1.1h4.8v-1.1c0-1.2.5-2.1 1.3-3 .8-.9 1.3-1.9 1.3-3.3 0-2.7-2.2-4.7-5-4.7Z" />
        <path d="M9.7 18.9h4.6" />
        <path d="M10.4 21h3.2" />
        <path d="M8.3 9.2c1.3-.5 2.4-.5 3.7 0 1.3.5 2.4.5 3.7 0" />
      </>
    )
  }
  {
    name === "location" && (
      <>
        <path d="M19 10.1c0 5.2-7 10.4-7 10.4s-7-5.2-7-10.4a7 7 0 0 1 14 0Z" />
        <circle cx="12" cy="10.1" r="2.3" />
      </>
    )
  }
  {
    name === "massage" && (
      <>
        <path d="M4 17.5c2.4-2.6 5-3.9 8-3.9s5.6 1.3 8 3.9" />
        <path d="M6.2 13.8c1.1-1.2 2.7-1.9 4.3-1.9h3" />
        <path d="M14.5 11.9c1.4 0 2.6-.9 3-2.2" />
        <path d="M8.3 7.2h7.4" />
        <path d="M10 4.5h4" />
        <path d="M7.5 19.5h9" />
      </>
    )
  }
  {
    name === "mat" && (
      <>
        <path d="M5.5 7.5h13a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-13a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2Z" />
        <path d="M7.5 7.5v9" />
        <path d="M16.5 7.5v9" />
        <path d="M9.5 12h5" />
      </>
    )
  }
  {
    name === "person" && (
      <>
        <circle cx="12" cy="7.5" r="3" />
        <path d="M5.2 20c1-3.6 3.3-5.4 6.8-5.4s5.8 1.8 6.8 5.4" />
        <path d="M8.5 20h7" />
      </>
    )
  }
  {
    name === "reformer" && (
      <>
        <path d="M4 15.5h16" />
        <path d="M6 12h8.5a2.5 2.5 0 0 1 2.5 2.5v1" />
        <path d="M7 9.5h4" />
        <path d="M18.5 7.5v8" />
        <path d="M5.5 18.5h13" />
        <circle cx="7" cy="18.5" r="1" />
        <circle cx="17" cy="18.5" r="1" />
      </>
    )
  }
  {
    name === "services" && (
      <>
        <path d="M5 5.5h5v5H5z" />
        <path d="M14 5.5h5v5h-5z" />
        <path d="M5 14h5v5H5z" />
        <path d="M14 14h5v5h-5z" />
      </>
    )
  }
  {
    name === "structure" && (
      <>
        <path d="M12 3.8v16.4" />
        <path d="M9 6.6c2-1.3 4-1.3 6 0" />
        <path d="M8.6 10.4c2.3-1.2 4.5-1.2 6.8 0" />
        <path d="M8.6 14.2c2.3 1.2 4.5 1.2 6.8 0" />
        <path d="M9 17.9c2 1.3 4 1.3 6 0" />
      </>
    )
  }
  {
    name === "time" && (
      <>
        <circle cx="12" cy="12" r="8" />
        <path d="M12 7.5V12l3.2 2" />
      </>
    )
  }
</svg>
