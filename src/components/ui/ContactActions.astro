---
import Button from "./Button.astro";

interface Props {
  phone: string;
  email: string;
  primaryVariant?: "primary" | "secondary" | "light" | "outlineLight";
  secondaryVariant?: "primary" | "secondary" | "light" | "outlineLight";
}

const {
  phone,
  email,
  primaryVariant = "primary",
  secondaryVariant = "secondary",
} = Astro.props;
const phoneHref = `tel:${phone.replace(/\s+/g, "")}`;
---

<div class="flex flex-wrap gap-3">
  <Button href={phoneHref} variant={primaryVariant}>Llamar para cita</Button>
  <Button href={`mailto:${email}`} variant={secondaryVariant}>
    Escribir email
  </Button>
</div>
