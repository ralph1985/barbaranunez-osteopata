---
import ContactActions from "../components/ui/ContactActions.astro";
import type { SiteContent } from "../domain/site";

interface Props {
  site: SiteContent;
}

const { site } = Astro.props;
---

<section class="hero">
  <div class="hero__content">
    <p class="eyebrow">Osteopatía - Pilates - Masaje deportivo</p>
    <h1>{site.claim}</h1>
    <p>{site.intro}</p>
    <ContactActions phone={site.contact.phone} email={site.contact.email} />
    <dl class="hero__facts" aria-label="Datos de la consulta">
      <div>
        <dt>Ubicación</dt>
        <dd>{site.contact.city}</dd>
      </div>
      <div>
        <dt>Cita previa</dt>
        <dd>{site.contact.phone}</dd>
      </div>
    </dl>
  </div>
  <figure class="hero__visual">
    <img
      src="/assets/clinic-placeholder.png"
      width="1586"
      height="992"
      alt="Consulta luminosa con camilla y equipo de pilates"
    />
    <figcaption>Consulta de osteopatía y pilates en Meco</figcaption>
  </figure>
</section>
