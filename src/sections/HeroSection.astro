---
import ContactActions from "../components/ui/ContactActions.astro";
import Icon from "../components/ui/Icon.astro";
import PhotoPlaceholder from "../components/ui/PhotoPlaceholder.astro";
import type { SiteContent } from "../domain/site";

interface Props {
  site: SiteContent;
}

const { site } = Astro.props;
---

<section class="hero page-shell" data-hero>
  <div class="hero__content" data-hero-content>
    <p class="eyebrow" data-hero-item>
      {site.hero.eyebrow}
    </p>
    <h1 class="hero__title" data-hero-item>
      {site.claim}
    </h1>
    <p class="hero__intro" data-hero-item>{site.intro}</p>
    <div data-hero-item>
      <ContactActions
        phone={site.contact.phone}
        email={site.contact.email}
        whatsappHref={site.contact.whatsappHref}
      />
    </div>
    <dl class="hero__facts" aria-label="Datos de la consulta" data-hero-item>
      <div class="hero__fact">
        <span class="icon-badge hero__fact-icon" aria-hidden="true">
          <Icon name="location" />
        </span>
        <div>
          <dt class="hero__fact-label">{site.hero.addressLabel}</dt>
          <dd class="hero__fact-value">
            {site.contact.address}<br />{site.contact.city}
          </dd>
        </div>
      </div>
      <div class="hero__fact">
        <span class="icon-badge hero__fact-icon" aria-hidden="true">
          <Icon name="appointment" />
        </span>
        <div>
          <dt class="hero__fact-label">{site.hero.appointmentLabel}</dt>
          <dd class="hero__fact-value">{site.contact.phone}</dd>
        </div>
      </div>
    </dl>
  </div>
  <PhotoPlaceholder
    eyebrow={site.hero.photo.eyebrow}
    title={site.hero.photo.title}
    description={site.hero.photo.description}
    aspectClass={site.hero.photo.aspectClass}
    waterScene
    data-hero-media
  />
</section>
