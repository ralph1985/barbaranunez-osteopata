---
import ContactPanel from "../components/ui/ContactPanel.astro";
import Icon from "../components/ui/Icon.astro";
import type { ContactInfo } from "../domain/site";

interface Props {
  contact: ContactInfo;
}

const { contact } = Astro.props;
---

<section
  class="contact page-shell section-space"
  id="contacto"
  aria-labelledby="contact-title"
>
  <div data-animate>
    <ContactPanel contact={contact} />
  </div>
  <div class="hours-card" data-animate>
    <span class="icon-badge hours-card__icon" aria-hidden="true">
      <Icon name="time" />
    </span>
    <h3 class="hours-card__title">{contact.copy.hoursTitle}</h3>
    <ul class="hours-card__list">
      {contact.hours.map((hour) => <li>{hour}</li>)}
    </ul>
  </div>
</section>
