---
import ContactPanel from "../components/ui/ContactPanel.astro";
import type { ContactInfo } from "../domain/site";

interface Props {
  contact: ContactInfo;
}

const { contact } = Astro.props;
---

<section
  class="mx-auto grid w-page grid-cols-[minmax(0,1fr)_minmax(320px,0.72fr)] items-start gap-8 py-20 max-lg:grid-cols-1 max-md:py-16"
  id="contacto"
  aria-labelledby="contact-title"
>
  <div data-animate>
    <ContactPanel contact={contact} />
  </div>
  <div
    class="min-h-64 rounded-md border border-line bg-surface/85 p-5 text-muted shadow-card"
    data-animate
  >
    <h3 class="mb-3 text-xl font-bold text-ink">Horario</h3>
    <ul class="list-disc space-y-2 pl-5">
      {contact.hours.map((hour) => <li>{hour}</li>)}
    </ul>
  </div>
</section>
