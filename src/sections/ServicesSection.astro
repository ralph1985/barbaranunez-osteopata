---
import SectionHeader from "../components/ui/SectionHeader.astro";
import ServiceCard from "../components/ui/ServiceCard.astro";
import type { Service } from "../domain/site";

interface Props {
  services: Service[];
}

const { services } = Astro.props;
---

<section
  class="mx-auto w-page py-20 max-md:py-16"
  id="servicios"
  aria-labelledby="services-title"
>
  <div data-animate>
    <SectionHeader
      eyebrow="Servicios"
      id="services-title"
      title="Tratamientos y clases para cuidar el movimiento"
    >
      <p>
        Sesiones orientadas a mejorar movilidad, fuerza, postura y recuperación
        física desde un trabajo progresivo y adaptado.
      </p>
    </SectionHeader>
  </div>
  <div
    class="grid grid-cols-5 gap-4 max-lg:grid-cols-2 max-md:grid-cols-1"
    data-animate-group
  >
    {services.map((service) => <ServiceCard service={service} />)}
  </div>
</section>
