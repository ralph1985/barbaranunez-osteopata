---
import SectionHeader from "../components/ui/SectionHeader.astro";
import ServiceCard from "../components/ui/ServiceCard.astro";
import type { SectionCopy, Service } from "../domain/site";

interface Props {
  intro: SectionCopy;
  services: Service[];
}

const { intro, services } = Astro.props;
---

<section
  class="mx-auto w-page py-20 max-md:py-16"
  id="servicios"
  aria-labelledby="services-title"
>
  <div data-animate>
    <SectionHeader
      eyebrow={intro.eyebrow}
      id="services-title"
      title={intro.title}
    >
      <p>{intro.description}</p>
    </SectionHeader>
  </div>
  <div
    class="grid grid-cols-5 gap-4 max-lg:grid-cols-2 max-md:grid-cols-1"
    data-animate-group
  >
    {services.map((service) => <ServiceCard service={service} />)}
  </div>
</section>
