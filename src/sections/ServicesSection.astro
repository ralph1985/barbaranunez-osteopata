---
import SectionHeader from "../components/ui/SectionHeader.astro";
import ServiceCard from "../components/ui/ServiceCard.astro";
import type { SectionCopy, Service } from "../domain/site";

interface Props {
  intro: SectionCopy;
  services: Service[];
}

const { intro, services } = Astro.props;
---

<section
  class="services page-shell section-space"
  id="servicios"
  aria-labelledby="services-title"
>
  <div data-animate>
    <SectionHeader
      eyebrow={intro.eyebrow}
      id="services-title"
      title={intro.title}
    >
      <p>{intro.description}</p>
    </SectionHeader>
  </div>
  <div class="services__grid" data-animate-group>
    {services.map((service) => <ServiceCard service={service} />)}
  </div>
</section>
