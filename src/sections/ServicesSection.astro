---
import type { Service } from "../domain/site";

interface Props {
  services: Service[];
}

const { services } = Astro.props;
---

<section class="section" id="servicios" aria-labelledby="services-title">
  <div class="section__header">
    <p class="eyebrow">Servicios</p>
    <h2 id="services-title">Tratamientos y clases para cuidar el movimiento</h2>
    <p>
      Sesiones orientadas a mejorar movilidad, fuerza, postura y recuperación
      física desde un trabajo progresivo y adaptado.
    </p>
  </div>
  <div class="services-grid">
    {
      services.map((service) => (
        <article class="service-card">
          <h3>{service.title}</h3>
          <p>{service.summary}</p>
        </article>
      ))
    }
  </div>
</section>
