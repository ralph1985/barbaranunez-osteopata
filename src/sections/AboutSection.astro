---
import PhotoPlaceholder from "../components/ui/PhotoPlaceholder.astro";
import SectionHeader from "../components/ui/SectionHeader.astro";
import type { AboutContent } from "../domain/site";

interface Props {
  about: AboutContent;
}

const { about } = Astro.props;
---

<section class="about" aria-labelledby="about-title">
  <div class="about__inner page-shell" data-animate>
    <div class="about__intro">
      <SectionHeader
        eyebrow={about.eyebrow}
        id="about-title"
        title={about.title}
      />
      <div class="about__body">
        {about.body.map((paragraph) => <p>{paragraph}</p>)}
      </div>
    </div>
    <div class="about__photos">
      {
        about.photos.map((photo) => (
          <PhotoPlaceholder
            eyebrow={photo.eyebrow}
            title={photo.title}
            description={photo.description}
            aspectClass={photo.aspectClass}
          />
        ))
      }
    </div>
    <div class="about__principles" aria-label="Enfoque de trabajo">
      {
        about.principles.map((principle) => (
          <article class="principle-card" data-animate>
            <span class="principle-card__number">{principle.number}</span>
            <h3 class="principle-card__title">{principle.title}</h3>
            <p class="principle-card__body">{principle.body}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<section
  class="approach page-shell section-space"
  aria-labelledby="approach-title"
  data-animate
>
  <SectionHeader
    eyebrow={about.approach.eyebrow}
    id="approach-title"
    title={about.approach.title}
  >
    <p>{about.approach.description}</p>
  </SectionHeader>
</section>
