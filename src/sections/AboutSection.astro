---
import SectionHeader from "../components/ui/SectionHeader.astro";
import type { AboutContent } from "../domain/site";

interface Props {
  about: AboutContent;
}

const { about } = Astro.props;
---

<section
  class="border-y border-line bg-[linear-gradient(90deg,rgba(232,239,230,0.86),rgba(242,223,207,0.52))] py-20 max-md:py-16"
  aria-labelledby="about-title"
>
  <div class="mx-auto w-page" data-animate>
    <div
      class="grid grid-cols-[minmax(0,0.9fr)_minmax(320px,0.78fr)] items-start gap-12 max-lg:grid-cols-1"
    >
      <SectionHeader
        eyebrow={about.eyebrow}
        id="about-title"
        title={about.title}
      />
      <div class="max-w-2xl space-y-4 text-lg text-muted">
        {about.body.map((paragraph) => <p>{paragraph}</p>)}
      </div>
    </div>
    <div
      class="mt-10 grid grid-cols-3 gap-4 max-md:grid-cols-1"
      aria-label="Enfoque de trabajo"
    >
      {
        about.principles.map((principle) => (
          <article
            class="min-h-48 rounded-md border border-line bg-surface/85 p-5 shadow-card"
            data-animate
          >
            <span class="text-sm font-extrabold text-warm">
              {principle.number}
            </span>
            <h3 class="mb-2 mt-3 text-xl font-bold">{principle.title}</h3>
            <p class="m-0 text-muted">{principle.body}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<section
  class="mx-auto w-page py-20 max-md:py-16"
  aria-labelledby="approach-title"
  data-animate
>
  <SectionHeader
    eyebrow={about.approach.eyebrow}
    id="approach-title"
    title={about.approach.title}
  >
    <p>{about.approach.description}</p>
  </SectionHeader>
</section>
