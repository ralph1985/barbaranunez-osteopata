---
import PageIntro from "../components/ui/PageIntro.astro";
import { getSiteContent } from "../infrastructure/content/local-site-repository";
import BaseLayout from "../layouts/BaseLayout.astro";
import ServicesSection from "../sections/ServicesSection.astro";

const site = await getSiteContent();
---

<BaseLayout
  site={site}
  currentPath="/servicios/"
  title={site.pages.services.metaTitle}
  description={site.pages.services.metaDescription}
>
  <PageIntro
    eyebrow={site.pages.services.eyebrow}
    title={site.pages.services.title}
    description={site.pages.services.description}
  />
  <ServicesSection intro={site.servicesIntro} services={site.services} />
</BaseLayout>
