---
import PageIntro from "../components/ui/PageIntro.astro";
import { getSiteContent } from "../infrastructure/content/local-site-repository";
import BaseLayout from "../layouts/BaseLayout.astro";
import AboutSection from "../sections/AboutSection.astro";

const site = await getSiteContent();
---

<BaseLayout
  site={site}
  currentPath="/sobre/"
  title={site.pages.about.metaTitle}
  description={site.pages.about.metaDescription}
>
  <PageIntro
    eyebrow={site.pages.about.eyebrow}
    title={site.pages.about.title}
    description={site.pages.about.description}
  />
  <AboutSection about={site.about} />
</BaseLayout>
