---
import PageIntro from "../components/ui/PageIntro.astro";
import { getSiteContent } from "../infrastructure/content/local-site-repository";
import BaseLayout from "../layouts/BaseLayout.astro";
import ContactSection from "../sections/ContactSection.astro";

const site = await getSiteContent();
---

<BaseLayout
  site={site}
  currentPath="/contacto/"
  title={site.pages.contact.metaTitle}
  description={site.pages.contact.metaDescription}
>
  <PageIntro
    eyebrow={site.pages.contact.eyebrow}
    title={site.pages.contact.title}
    description={site.pages.contact.description}
  />
  <ContactSection contact={site.contact} />
</BaseLayout>
