---
import { getSiteContent } from "../infrastructure/content/local-site-repository";
import Icon from "../components/ui/Icon.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroSection from "../sections/HeroSection.astro";

const site = await getSiteContent();
---

<BaseLayout site={site}>
  <HeroSection site={site} />
  <section class="home-cards" aria-labelledby="home-pages-title">
    <div class="home-cards__inner page-shell">
      <h2 id="home-pages-title" class="sr-only">Secciones principales</h2>
      <div class="home-cards__grid" data-animate-group>
        {
          site.homeCards.map((card) => (
            <a class="home-card" href={card.href}>
              <span class="icon-badge home-card__icon" aria-hidden="true">
                <Icon name={card.icon} />
              </span>
              <p class="eyebrow">{card.eyebrow}</p>
              <h3 class="home-card__title">{card.title}</h3>
              <p class="home-card__summary">{card.summary}</p>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
