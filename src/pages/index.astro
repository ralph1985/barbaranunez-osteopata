---
import { getSiteContent } from "../infrastructure/content/local-site-repository";
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroSection from "../sections/HeroSection.astro";

const site = await getSiteContent();
const homeCards = [
  {
    href: "/sobre/",
    eyebrow: "Sobre Bárbara",
    title: "Atención personalizada",
    summary:
      "Conoce el enfoque de trabajo y la forma de acompañar cada proceso.",
  },
  {
    href: "/servicios/",
    eyebrow: "Servicios",
    title: "Osteopatía, masaje y pilates",
    summary:
      "Consulta los tratamientos y clases disponibles para cuidar el movimiento.",
  },
  {
    href: "/contacto/",
    eyebrow: "Contacto",
    title: "Cita previa",
    summary:
      "Accede a WhatsApp, teléfono, email, dirección y horario de la consulta.",
  },
];
---

<BaseLayout site={site}>
  <HeroSection site={site} />
  <section
    class="border-y border-line bg-soft/55 py-16 max-md:py-12"
    aria-labelledby="home-pages-title"
  >
    <div class="mx-auto w-page">
      <h2 id="home-pages-title" class="sr-only">Secciones principales</h2>
      <div class="grid grid-cols-3 gap-4 max-lg:grid-cols-1" data-animate-group>
        {
          homeCards.map((card) => (
            <a
              class="min-h-56 rounded-md border border-line bg-surface/90 p-5 text-ink no-underline shadow-card transition-transform hover:-translate-y-1 hover:border-accent-strong"
              href={card.href}
            >
              <p class="mb-3 text-xs font-extrabold tracking-wide text-accent-strong uppercase">
                {card.eyebrow}
              </p>
              <h3 class="mb-3 mt-0 text-2xl leading-tight font-bold">
                {card.title}
              </h3>
              <p class="m-0 text-muted">{card.summary}</p>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
