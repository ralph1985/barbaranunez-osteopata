---
import { getSiteContent } from "../../infrastructure/content/local-site-repository";
import BaseLayout from "../../layouts/BaseLayout.astro";
import LegalContent from "../../components/ui/LegalContent.astro";

const site = await getSiteContent();
---

<BaseLayout
  site={site}
  currentPath="/legal/cookies/"
  title="Política de cookies"
  description="Política de cookies de la web de Bárbara Núñez Osteópata."
>
  <LegalContent title="Política de cookies">
    <p>
      En su V1, esta web no incorpora cookies analíticas, publicitarias ni
      contenidos externos incrustados que requieran consentimiento previo.
    </p>
    <section>
      <h2>Cookies técnicas</h2>
      <p>
        La web se publica como sitio estático y no necesita instalar cookies
        propias para mostrar sus contenidos principales.
      </p>
    </section>
    <section>
      <h2>Cambios futuros</h2>
      <p>
        Si más adelante se añaden analítica, mapas, vídeos, formularios externos
        o servicios de terceros, esta página deberá revisarse antes de publicar
        esos cambios.
      </p>
    </section>
  </LegalContent>
</BaseLayout>
