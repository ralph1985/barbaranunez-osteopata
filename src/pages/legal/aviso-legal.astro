---
import { getSiteContent } from "../../infrastructure/content/local-site-repository";
import BaseLayout from "../../layouts/BaseLayout.astro";
import LegalContent from "../../components/ui/LegalContent.astro";

const site = await getSiteContent();
---

<BaseLayout site={site} currentPath="/legal/aviso-legal/">
  <LegalContent title="Aviso legal">
    <p>
      Texto pendiente de validación. No publicar como definitivo hasta confirmar
      datos legales de titularidad, actividad, domicilio fiscal y condiciones de
      uso.
    </p>
  </LegalContent>
</BaseLayout>
