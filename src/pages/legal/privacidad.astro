---
import { getSiteContent } from "../../infrastructure/content/local-site-repository";
import BaseLayout from "../../layouts/BaseLayout.astro";

const site = await getSiteContent();
---

<BaseLayout site={site} currentPath="/legal/privacidad/">
  <section class="section legal-page">
    <p class="eyebrow">Legal</p>
    <h1>Política de privacidad</h1>
    <p>
      Texto pendiente de validación. No publicar como definitivo hasta confirmar
      responsable del tratamiento, finalidad, base legal, conservación y
      derechos.
    </p>
  </section>
</BaseLayout>
