---
import { getSiteContent } from "../../infrastructure/content/local-site-repository";
import BaseLayout from "../../layouts/BaseLayout.astro";
import LegalContent from "../../components/ui/LegalContent.astro";

const site = await getSiteContent();
---

<BaseLayout
  site={site}
  currentPath="/legal/privacidad/"
  title="Política de privacidad"
  description="Base revisable de la política de privacidad de Bárbara Núñez Osteópata."
>
  <LegalContent title="Política de privacidad">
    <p>
      Esta política es una base revisable. El texto definitivo debe validarse
      antes de publicar con los datos completos de la persona responsable del
      tratamiento.
    </p>
    <section>
      <h2>Responsable del tratamiento</h2>
      <p>
        Pendiente de confirmar: nombre legal, NIF/CIF, domicilio fiscal y correo
        de contacto para privacidad.
      </p>
    </section>
    <section>
      <h2>Datos tratados</h2>
      <p>
        La V1 de esta web no incluye formularios. Los datos personales solo se
        enviarían si la persona visitante contacta de forma voluntaria por
        teléfono o correo electrónico.
      </p>
    </section>
    <section>
      <h2>Finalidad</h2>
      <p>
        Responder solicitudes de información, gestionar citas y atender
        comunicaciones relacionadas con los servicios ofrecidos.
      </p>
    </section>
    <section>
      <h2>Derechos</h2>
      <p>
        El texto definitivo debe indicar cómo ejercer los derechos de acceso,
        rectificación, supresión, oposición, limitación y portabilidad cuando
        proceda.
      </p>
    </section>
  </LegalContent>
</BaseLayout>
