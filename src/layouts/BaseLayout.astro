---
import ContactActions from "../components/ui/ContactActions.astro";
import type { SiteContent } from "../domain/site";
import { getAbsoluteUrl } from "../config/site-url";
import "../styles/global.css";

interface Props {
  site: SiteContent;
  currentPath?: string;
  title?: string;
  description?: string;
}

const {
  site,
  currentPath = "/",
  title = site.title,
  description = site.description,
} = Astro.props;
const canonicalUrl = getAbsoluteUrl(currentPath);
const pageTitle =
  title === site.title ? title : `${title} | ${site.businessName}`;
---

<!doctype html>
<html lang={site.lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <title>{pageTitle}</title>
  </head>
  <body class="overflow-x-hidden">
    <header
      class="sticky top-0 z-30 border-b border-line bg-bg/90 backdrop-blur-md"
    >
      <div class="mx-auto flex w-page items-center justify-between gap-6 py-3">
        <a
          class="font-bold text-accent-strong no-underline"
          href="/"
          aria-current={currentPath === "/" ? "page" : undefined}
        >
          {site.businessName}
        </a>
        <nav class="hidden" aria-label="Navegacion principal">
          {
            site.nav.map((item) => (
              <a
                class="text-[0.95rem] text-muted no-underline hover:text-accent-strong"
                href={item.href}
                aria-current={currentPath === item.href ? "page" : undefined}
              >
                {item.label}
              </a>
            ))
          }
        </nav>
        <button
          class="inline-flex min-h-11 items-center gap-3 rounded-md border border-line bg-surface px-4 py-2 font-bold text-accent-strong shadow-card"
          type="button"
          aria-controls="site-menu"
          aria-expanded="false"
          data-menu-open
        >
          <span>Menú</span>
          <span class="grid gap-1" aria-hidden="true">
            <span class="block h-0.5 w-5 rounded-full bg-accent-strong"></span>
            <span class="block h-0.5 w-5 rounded-full bg-accent-strong"></span>
            <span class="block h-0.5 w-5 rounded-full bg-accent-strong"></span>
          </span>
        </button>
      </div>
    </header>
    <div
      class="fixed inset-0 z-40 hidden bg-ink/40 opacity-0 transition-opacity"
      data-menu-overlay
    >
    </div>
    <aside
      id="site-menu"
      class="fixed top-0 right-0 z-50 flex h-dvh w-[min(24rem,calc(100%-2rem))] translate-x-full flex-col gap-8 border-l border-line bg-surface p-6 shadow-soft transition-transform"
      aria-label="Menú principal"
      aria-hidden="true"
      data-menu-panel
    >
      <div class="flex items-center justify-between gap-4">
        <p class="m-0 font-bold text-accent-strong">{site.businessName}</p>
        <button
          class="inline-flex min-h-10 min-w-10 items-center justify-center rounded-md border border-line bg-bg text-2xl leading-none text-accent-strong"
          type="button"
          aria-label="Cerrar menú"
          data-menu-close
        >
          ×
        </button>
      </div>
      <nav class="grid gap-3" aria-label="Navegación lateral">
        {
          site.nav.map((item) => (
            <a
              class="rounded-md border border-line px-4 py-3 text-lg font-bold text-ink no-underline hover:border-accent-strong hover:text-accent-strong"
              href={item.href}
              aria-current={currentPath === item.href ? "page" : undefined}
              data-menu-link
            >
              {item.label}
            </a>
          ))
        }
      </nav>
      <div class="mt-auto">
        <ContactActions
          phone={site.contact.phone}
          email={site.contact.email}
          whatsappHref={site.contact.whatsappHref}
        />
      </div>
    </aside>
    <main>
      <slot />
    </main>
    <footer
      class="mx-auto flex w-page items-center justify-between gap-6 border-t border-line py-4 text-muted max-md:flex-col max-md:items-start"
    >
      <p>{site.businessName} - {site.footer}</p>
      <nav class="flex flex-wrap gap-3" aria-label="Legal">
        <a
          class="text-[0.95rem] no-underline hover:text-accent-strong"
          href="/legal/aviso-legal/">Aviso legal</a
        >
        <a
          class="text-[0.95rem] no-underline hover:text-accent-strong"
          href="/legal/privacidad/">Privacidad</a
        >
        <a
          class="text-[0.95rem] no-underline hover:text-accent-strong"
          href="/legal/cookies/">Cookies</a
        >
      </nav>
    </footer>
    <script>
      import "../scripts/site.js";
    </script>
  </body>
</html>
