---
import ContactActions from "../components/ui/ContactActions.astro";
import type { SiteContent } from "../domain/site";
import { getAbsoluteUrl } from "../config/site-url";
import "../styles/global.scss";

interface Props {
  site: SiteContent;
  currentPath?: string;
  title?: string;
  description?: string;
}

const {
  site,
  currentPath = "/",
  title = site.title,
  description = site.description,
} = Astro.props;
const canonicalUrl = getAbsoluteUrl(currentPath);
const pageTitle =
  title === site.title ? title : `${title} | ${site.businessName}`;
---

<!doctype html>
<html lang={site.lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <title>{pageTitle}</title>
  </head>
  <body class="site-body">
    <header class="site-header">
      <div class="site-header__inner page-shell">
        <a
          class="site-brand"
          href="/"
          aria-current={currentPath === "/" ? "page" : undefined}
        >
          {site.businessName}
        </a>
        <nav
          class="site-nav site-nav--hidden"
          aria-label="Navegacion principal"
        >
          {
            site.nav.map((item) => (
              <a
                class="site-nav__link"
                href={item.href}
                aria-current={currentPath === item.href ? "page" : undefined}
              >
                {item.label}
              </a>
            ))
          }
        </nav>
        <button
          class="menu-button"
          type="button"
          aria-controls="site-menu"
          aria-expanded="false"
          data-menu-open
        >
          <span>Menú</span>
          <span class="menu-button__lines" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
          </span>
        </button>
      </div>
    </header>
    <div class="menu-overlay is-hidden" data-menu-overlay></div>
    <aside
      id="site-menu"
      class="site-menu is-closed"
      aria-label="Menú principal"
      aria-hidden="true"
      data-menu-panel
    >
      <div class="site-menu__header">
        <p class="site-menu__brand">{site.businessName}</p>
        <button
          class="site-menu__close"
          type="button"
          aria-label="Cerrar menú"
          data-menu-close
        >
          ×
        </button>
      </div>
      <nav class="site-menu__nav" aria-label="Navegación lateral">
        {
          site.nav.map((item) => (
            <a
              class="site-menu__link"
              href={item.href}
              aria-current={currentPath === item.href ? "page" : undefined}
              data-menu-link
            >
              {item.label}
            </a>
          ))
        }
      </nav>
      <div class="site-menu__actions">
        <ContactActions
          phone={site.contact.phone}
          email={site.contact.email}
          whatsappHref={site.contact.whatsappHref}
          facebookHref={site.contact.facebookHref}
        />
      </div>
    </aside>
    <main>
      <slot />
    </main>
    <footer class="site-footer page-shell">
      <p>{site.businessName} - {site.footer}</p>
      <nav class="site-footer__nav" aria-label="Legal">
        <a class="site-footer__link" href="/legal/aviso-legal/">Aviso legal</a>
        <a class="site-footer__link" href="/legal/privacidad/">Privacidad</a>
        <a class="site-footer__link" href="/legal/cookies/">Cookies</a>
      </nav>
    </footer>
    <script>
      import "../scripts/site.js";
    </script>
  </body>
</html>
