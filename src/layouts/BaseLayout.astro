---
import type { SiteContent } from "../domain/site";
import { getAbsoluteUrl } from "../config/site-url";
import "../styles/global.css";

interface Props {
  site: SiteContent;
  currentPath?: string;
  title?: string;
  description?: string;
}

const {
  site,
  currentPath = "/",
  title = site.title,
  description = site.description,
} = Astro.props;
const canonicalUrl = getAbsoluteUrl(currentPath);
const pageTitle =
  title === site.title ? title : `${title} | ${site.businessName}`;
const socialImageUrl = getAbsoluteUrl("/assets/clinic-placeholder.png");
---

<!doctype html>
<html lang={site.lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <header
      class="mx-auto flex w-page items-center justify-between gap-6 py-4 max-md:flex-col max-md:items-start"
    >
      <a
        class="font-bold text-accent-strong no-underline"
        href="/"
        aria-current={currentPath === "/" ? "page" : undefined}
      >
        {site.businessName}
      </a>
      <nav class="flex flex-wrap gap-3" aria-label="Navegacion principal">
        {
          site.nav.map((item) => (
            <a
              class="text-[0.95rem] text-muted no-underline hover:text-accent-strong"
              href={item.href}
              aria-current={currentPath === item.href ? "page" : undefined}
            >
              {item.label}
            </a>
          ))
        }
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer
      class="mx-auto flex w-page items-center justify-between gap-6 border-t border-line py-4 text-muted max-md:flex-col max-md:items-start"
    >
      <p>{site.businessName} - Osteopatía y pilates en Meco.</p>
      <nav class="flex flex-wrap gap-3" aria-label="Legal">
        <a
          class="text-[0.95rem] no-underline hover:text-accent-strong"
          href="/legal/aviso-legal/">Aviso legal</a
        >
        <a
          class="text-[0.95rem] no-underline hover:text-accent-strong"
          href="/legal/privacidad/">Privacidad</a
        >
        <a
          class="text-[0.95rem] no-underline hover:text-accent-strong"
          href="/legal/cookies/">Cookies</a
        >
      </nav>
    </footer>
  </body>
</html>
