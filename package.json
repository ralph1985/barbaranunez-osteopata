{
  "name": "barbaranunez-osteopata",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.25.0",
  "scripts": {
    "dev": "ASTRO_TELEMETRY_DISABLED=1 astro dev",
    "build": "ASTRO_TELEMETRY_DISABLED=1 astro build",
    "preview": "ASTRO_TELEMETRY_DISABLED=1 astro preview",
    "log:time": "node scripts/log-time.mjs",
    "lint": "pnpm run lint:astro && pnpm run format:check",
    "lint:astro": "ASTRO_TELEMETRY_DISABLED=1 astro check",
    "format:check": "prettier --check package.json astro.config.mjs tsconfig.json prettier.config.mjs vercel.json \"src/**/*.{astro,ts,js,json,css}\" \"scripts/**/*.mjs\" \"docs/**/*.md\" AGENTS.md README.md PROJECT_CONTEXT.md"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "animejs": "4.5.0",
    "astro": "7.0.4",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@types/node": "26.0.1",
    "prettier": "3.9.4",
    "prettier-plugin-astro": "0.14.1",
    "typescript": "6.0.3"
  }
}
